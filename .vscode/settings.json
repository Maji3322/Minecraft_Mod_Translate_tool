{
    "git.enableSmartCommit": true,
    "code-runner.runInTerminal": true,
    "files.autoSave": "afterDelay",
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "git.openRepositoryInParentFolders": "never",
    "files.associations": {
        "*.mcmeta": "json",
        "*.html": "html"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "vsicons.dontShowNewVersionMessage": true,
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": ["/k", "chcp", "65001"],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        }
    },
    "terminal.integrated.fontSize": 23,
    "workbench.editorAssociations": {
        "*.log": "default",
        "*.xlsx": "default"
    },
    "python.defaultInterpreterPath": "${workspaceFolder}\\.conda\\python.exe",
    "prettier.tabWidth": 4,
    "terminal.integrated.fontFamily": "Bizin Gothic Discord",
    "livePreview.customExternalBrowser": "Edge",
    "livePreview.previewDebounceDelay": 100,
    "livePreview.serverKeepAliveAfterEmbeddedPreviewClose": 1,
    "livePreview.showServerStatusNotifications": false,
    "livePreview.tasks.runTaskWithExternalPreview": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false,
        "properties": false,
        "json": true,
        "python": true,
        "cpp": false,
        "shellscript": false
    },
    "debug.console.fontFamily": "Hack",
    "chat.editor.fontFamily": "Hack",
    "notebook.output.fontFamily": "Hack",
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "livePreview.notifyOnOpenLooseFile": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "always"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "accessibility.voice.speechLanguage": "ja-JP",
    "accessibility.voice.speechTimeout": 1800000,
    "git.postCommitCommand": "push",
    "remoteHub.commitDirectlyWarning": "off",
    "git.autofetch": true,
    "git.confirmSync": false,
    "github.copilot.editor.enableAutoCompletions": true,
    "editor.inlayHints.fontFamily": "Bizin Gothic Discord",
    "scm.inputFontFamily": "Bizin Gothic Discord",
    "liveshare.launcherClient": "visualStudioCode",
    "liveshare.nameTagVisibility": "Always",
    "liveshare.anonymousGuestApproval": "accept",
    "liveshare.increasedGuestLimit": false,
    "workbench.colorTheme": "Default Dark+",
    "terminal.integrated.scrollback": 10000,
    "redhat.telemetry.enabled": false,
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "workbench.startupEditor": "none",
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.formatOnSave": true,
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "editor.cursorSurroundingLines": 15,
    "editor.cursorStyle": "line",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.wordWrap": "off",
    "diffEditor.wordWrap": "off",
    "editor.guides.indentation": false,
    "editor.fontLigatures": true,
    "animations.Install-Method": "Apc Customize UI++",
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 6,
    "apc.imports": [
        "file:///c:/Users/kazuy/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.3/dist/updateHandler.js"
    ],
    "files.exclude": {
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "files.watcherExclude": {
        "**/.next/**": true,
        "**/.trunk/*actions/": true,
        "**/.trunk/*logs/": true,
        "**/.trunk/*notifications/": true,
        "**/.trunk/*out/": true,
        "**/.trunk/*plugins/": true
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.minimap.renderCharacters": false,
    "files.insertFinalNewline": true,
    "workbench.tree.indent": 30,
    "blockman.n03MaxDepth": 4,
    "blockman.n34A01BorderThicknessOfNonFocusedBlock": 0,
    "python.analysis.inlayHints.callArgumentNames": "all",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "editor.inlayHints.padding": true,
    "python.analysis.inlayHints.pytestParameters": true,
    "javascript.inlayHints.enumMemberValues.enabled": true,
    "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
    "javascript.inlayHints.parameterNames.enabled": "literals",
    "javascript.inlayHints.parameterTypes.enabled": true,
    "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
    "javascript.inlayHints.variableTypes.enabled": true,
    "typescript.inlayHints.enumMemberValues.enabled": true,
    "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
    "typescript.inlayHints.parameterNames.enabled": "literals",
    "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
    "typescript.inlayHints.parameterTypes.enabled": true,
    "typescript.inlayHints.variableTypes.enabled": true,
    "github.copilot.chat.localeOverride": "ja",
    "editor.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "animations.Enabled": true,
    "animations.Command-Palette": "Fade",
    "animations.Active": "Indent",
    "animations.CursorAnimation": true,
    "terminal.integrated.cursorBlinking": true,
    "animations.Smooth-Mode": false,
    "workbench.list.smoothScrolling": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "github.copilot.chat.search.semanticTextResults": true,
    "chat.commandCenter.enabled": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "github.copilot.chat.codeGeneration.instructions": [
        {
            "text": "説明するときに高校生向けにわかりやすく説明してください。常に常体を使用してください。もし、OpenAI APIを使うときにはモデルを'gpt-4o-mini-2024-07-18'としてください。"
        },
        {
            "file": "rules.md"
        }
    ],
    "github.copilot.chat.temporalContext.enabled": true,
    "github.copilot.chat.followUps": "always",
    "copilot.vision.model": "gemini-1.5-flash",
    "copilot.vision.provider": "Gemini",
    "apc.font.family": "Noto Sans JP",
    "apc.monospace.font.family": "Hackgen Console NF",
    "githubPullRequests.createOnPublishBranch": "never",
    "gitlens.graph.minimap.additionalTypes": [
        "localBranches",
        "stashes",
        "tags"
    ],
    "tailwind-fold.autoFold": false,
    "tailwind-fold.unfoldIfLineSelected": true,
    "markdown.preview.fontFamily": "'Noto Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
    "markdown.preview.breaks": true,
    "chat.detectParticipant.enabled": true,
    "roo-cline.allowedCommands": [
        "npm test",
        "npm install",
        "tsc",
        "git log",
        "git diff",
        "git show",
        "pip install"
    ],
    "github.copilot.chat.completionContext.typescript.mode": "on",
    "python.testing.pytestArgs": ["."],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true
}
