# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# OpenRouter Model (use free models for testing)
# Free models: meta-llama/llama-3.2-3b-instruct:free, google/gemini-flash-1.5:free, etc.
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
